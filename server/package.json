{
  "name": "gps-mock",
  "version": "2.1.0",
  "description": "GPS location spoofer for iPhone via pymobiledevice3",
  "main": "main.js",
  "scripts": {
    "start": "npm run vite:build && electron .",
    "dev": "vite",
    "build": "electron-builder --win --x64",
    "vite:build": "vite build",
    "test": "jest"
  },
  "build": {
    "appId": "com.gpsmock.app",
    "productName": "GPS Mock",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GPS Mock"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "dist-web/**",
      "!resources/python"
    ],
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/test",
          "!**/tests",
          "!**/docs",
          "!**/idlelib",
          "!**/turtledemo",
          "!**/get-pip.py"
        ]
      },
      {
        "from": "src/main/python",
        "to": "python_scripts"
      }
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0"
  }
}
